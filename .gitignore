# ──────────────────────────────────────────────────────────────────────────
# Secrets and credentials — NEVER commit these
# ──────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
secrets.toml
.streamlit/secrets.toml
credentials.json
service-account*.json
aws-credentials
**/.aws/

# ──────────────────────────────────────────────────────────────────────────
# Terraform
# ──────────────────────────────────────────────────────────────────────────
**/.terraform/
**/.terraform.lock.hcl.backup
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
!terraform.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ──────────────────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
.env/
*.egg-info/
.eggs/
build/
dist/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
.pyre/

# ──────────────────────────────────────────────────────────────────────────
# Node / Frontend
# ──────────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
dist/
build/
.vite/
.turbo/
.next/
.cache/

# ──────────────────────────────────────────────────────────────────────────
# Editors / IDEs
# ──────────────────────────────────────────────────────────────────────────
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.iml
*.swp
*.swo
*~
.project
.classpath

# ──────────────────────────────────────────────────────────────────────────
# OS
# ──────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ──────────────────────────────────────────────────────────────────────────
# Logs / debug
# ──────────────────────────────────────────────────────────────────────────
*.log
logs/
.claude-local/

